{
  "rate_guard": {
    "rules": {
      "instagram_*": { "max": 30, "window": 3600 },
      "camoufox_*": { "max": 10, "window": 60 },
      "mcp__supabase__*": { "max": 100, "window": 60 }
    }
  },
  "quality_gate": {
